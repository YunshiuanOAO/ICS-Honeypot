# Honeypot Client Agent Environment Example
# Copy this file to client/.env and set API_KEY to match server/.env.

# Required: must match server/.env API_KEY.
API_KEY=change-this-to-match-server-api-key

# Optional default Server URL used when client_config.json does not exist.
# Normal deployments should still set server_url in client/client_config.json.
CLIENT_SERVER_URL=http://127.0.0.1:8000

# Optional Agent behavior tuning
AGENT_SYNC_INTERVAL=15
AGENT_REQUEST_TIMEOUT=15
AGENT_UPLOAD_BATCH_SIZE=200
AGENT_COLLECT_MAX_LINES_PER_FILE=5000

# Local SQLite log retention and cleanup interval
CLIENT_LOG_RETENTION_DAYS=30
CLIENT_LOG_CLEANUP_INTERVAL_SECONDS=3600

# Optional custom whitelist file path
WHITELIST_PATH=whitelist.json
