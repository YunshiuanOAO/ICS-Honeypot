# Honeypot Server Environment Example
# Copy this file to server/.env and replace every change-me value.

# Web dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Shared key used by Honeypot Agents and ElastAlert webhooks.
# This value must match client/.env API_KEY.
API_KEY=change-this-shared-agent-key

# Secret used to sign browser sessions.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-session-secret

# FastAPI listen port used by server/main.py and server/start_services.sh.
SERVER_PORT=8000

# Public URL used by remote Agents.
# Leave empty to auto-detect from request headers.
# Example: SERVER_PUBLIC_URL=https://honeypot.example.com
# Example with custom port: SERVER_PUBLIC_URL=http://203.0.113.10:8081
SERVER_PUBLIC_URL=

# Optional custom Kibana URL shown in the dashboard.
# Leave empty to use http://localhost:5601.
KIBANA_URL=

# PostgreSQL settings used by server/elk/docker-compose.yml.
POSTGRES_DB=honeypot
POSTGRES_USER=honeypot
POSTGRES_PASSWORD=honeypot_change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://honeypot:honeypot_change_me@127.0.0.1:5432/honeypot

# Optional server tuning
AGENT_OFFLINE_AFTER_SECONDS=300
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT_SECONDS=30
IP_ANALYSIS_SCAN_ROWS=2000
IP_ANALYSIS_ALERT_SCAN_ROWS=10000
IP_ANALYSIS_QUERY_TIMEOUT_SECONDS=5
DB_MAINTENANCE_ON_STARTUP=false

# Optional package generator defaults
MODBUS_PORT=5020
MQTT_BROKER_HOST=mqtt-broker
MQTT_BROKER_PORT=1883
