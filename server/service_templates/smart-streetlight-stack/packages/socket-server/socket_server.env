# TCP Management Server (VM-B) — 全 TCP，無 HTTP
# 拓撲：對等雙通道 + Bridge（subscriber 作為 bridge client）
#   UPSTREAM   real 15567 / proxy 5567：server listen，gateway 經 proxy 5567 dial 進來送回報
#   BRIDGE     real 15568 / proxy 5568：server listen，subscriber 經 proxy 5568 dial 進來送指令
#   GATEWAYS   下行通道目標：server 經 proxy 5566 dial 過去，proxy 轉到 gateway:15566
TCP_HOST=0.0.0.0
# UPSTREAM 真實 listen（外部 client 經 proxy 5567 轉進來）
UPSTREAM_PORT=15567
# BRIDGE 真實 listen（subscriber 經 proxy 5568 轉進來）
BRIDGE_PORT=15568

# 下行 dial 目標：走 proxy 5566（直連請改 15566）。多台用逗號隔開：
#   GATEWAYS=10.0.0.5:5566,10.0.0.6:5566
GATEWAYS=host.docker.internal:5566

# 將 Gateway 上行訊息同步轉送到 subscriber 的 /api/messages，維持原本 UI 即時推送。
# node_3: subscriber
SUBSCRIBER_API_URL=http://host.docker.internal:8080/api/messages

# Bearer Token（HTTP /api/commands 與轉送 subscriber 共用，可分別設定）
# API_TOKEN=change-me
# SUBSCRIBER_API_TOKEN=change-me

# MongoDB 連線（與 mongodb/mongodb.env 同帳密；authSource=admin）
# VM-B 同機部署時 host 用 docker service 名稱 `mongo`；跨機填內網位址
MONGO_URI=mongodb://streetlight_admin:Hn8KQZ3vR6tY9xA2@host.docker.internal:27017/streetlight?authSource=admin
MONGO_DB=streetlight
